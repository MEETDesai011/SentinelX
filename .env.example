# SentinelX V7 Global Configuration Example
NODE_ENV=development
JWT_SECRET=super_secret_jwt_key_2026

# PostgreSQL Connection
DATABASE_URL="postgresql://postgres:password123@localhost:5432/sentinelx?schema=public"

# Neo4j Graph Connection
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="password123"

# Microservices URLs (Local Dev Hops)
SCAM_SERVICE_URL="http://localhost:8001"
FRAUD_GRAPH_URL="http://localhost:8002"
CITIZEN_SHIELD_URL="http://localhost:8003"
THREAT_FUSION_URL="http://localhost:8004"
EVIDENCE_SERVICE_URL="http://localhost:8005"
COUNTERFEIT_SERVICE_URL="http://localhost:8006"

# Redis Cache Connection
REDIS_URL="redis://localhost:6379/0"

# Kafka Messaging Connection
KAFKA_BOOTSTRAP_SERVERS="localhost:9092"
